{
  "compilerOptions": {
    "composite": true,
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,
    
    /* Bundler mode */
    "moduleResolution": "bundler",
    "noEmit": true,
    "moduleDetection": "force"
  },
  "include": ["vite.config.ts"]
}